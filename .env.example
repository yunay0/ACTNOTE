# =====================================================================
# ACTNOTE 환경변수 예시 — 실제 값을 .env 에 넣고 커밋하지 마세요.
# =====================================================================

# OpenAI (STT, LLM 추출)
OPENAI_API_KEY=sk-...

# Anthropic (선택)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace (화자 분리)
HUGGINGFACE_TOKEN=hf_...

# Supabase (서버 전용 — 클라이언트 코드에 절대 노출 금지)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

SUPABASE_STORAGE_BUCKET=meetings

# 로컬 테스트용 UUID (Supabase DB에 실제 존재해야 함)
ACTNOTE_TEST_USER_ID=
ACTNOTE_TEST_WORKSPACE_ID=

# Cost guardrails
MAX_COST_PER_MEETING_USD=1.0
MAX_TOTAL_COST_USD=10.0
COST_GUARDRAIL_AUTO_APPROVE=false

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_IS_PRODUCTION=false

# SEC-009: Notion 토큰 암호화 키 (Fernet)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ACTNOTE_ENCRYPTION_KEY=

# Notion 로컬 테스트 (notion_client.py 단독 실행 시)
NOTION_TEST_TOKEN=secret_...
NOTION_TEST_PARENT_PAGE_ID=
