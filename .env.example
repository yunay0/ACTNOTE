# =============================================================================
# ACTNOTE 환경변수 예시 — 실제 값을 .env 에 넣고 절대 커밋하지 마세요.
# (.env 는 .gitignore 에 포함돼 있음)
# =============================================================================
#
# ┌─ 팀원 로컬 QA (Notion 연동 전) ───────────────────────────────────────────
# │
# │  1) 이 파일을 복사해 레포 루트에 `.env` 생성 → 아래 [필수] 전부 채우기
# │  2) `actnote-web/.env.example` → `actnote-web/.env.local` 로 복사 후 웹 변수 채우기
# │  3) 터미널 A: `uv run python scripts/serve_worker.py`  (:8000)
# │  4) 터미널 B: `npx inngest-cli@latest dev -u http://127.0.0.1:8000/api/inngest`
# │             → 웹 `actnote-web/.env.local` 의 INNGEST_EVENT_KEY 는 로컬에서 **임의 문자열**(예: local-dev)로 충분 (Dev 서버는 키를 검증하지 않음). 운영 키는 Inngest Cloud 에서 발급.
# │  5) 터미널 C: `cd actnote-web && npm run dev`
# │  ─ Notion 발행·OAuth 는 NOTION_* 가 있을 때만. QA 생략 시 비워 두면 됨.
# │
# └────────────────────────────────────────────────────────────────────────────
#
# 마지막 업데이트: 2026-05-11


# -----------------------------------------------------------------------------
# [필수] AI 모델 API 키
# -----------------------------------------------------------------------------

# OpenAI — Whisper STT + 임베딩 (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Anthropic — Claude Sonnet 4.6 (요약/액션 추출/A.U.D.N/화자 추측)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace — pyannote/speaker-diarization-3.1 다운로드용
# 모델 라이선스 동의 필수:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=hf_...


# -----------------------------------------------------------------------------
# [선택] 화자분리 Modal GPU 오프로딩  (Modal 배포 완료: 2026-05-18)
# -----------------------------------------------------------------------------
# true (운영/권장): Modal GPU 함수 호출. CPU 30분+ → Inngest 타임아웃(500) 회피.
# false           : 로컬 pyannote (CPU/GPU). GPU 없는 로컬 단독 디버깅용.
#   선행 조건 (true):
#     1) `modal deploy src/modal_diarization.py`  → 배포됨 (앱: actnote-diarization)
#        https://modal.com/apps/ttojo6/main/deployed/actnote-diarization
#     2) Modal Secret "actnote-secrets" 에 HUGGINGFACE_TOKEN 등록
#     3) 워커 환경에 Modal 인증 (`modal token set` 또는 MODAL_TOKEN_ID/MODAL_TOKEN_SECRET)
#   동작: 워커가 Supabase signed URL 을 만들어 Modal 에 전달 (service_role 키는 Modal 미전달).
#   주의: Modal 실패 시 로컬 CPU 폴백 안 함 (타임아웃 재발 방지) → 명시적 에러 처리.
USE_MODAL_DIARIZATION=true
# Modal 에 넘길 signed URL 유효시간(초). 긴 회의 + Inngest 재시도 여유 포함 (기본 3600).
MODAL_DIARIZATION_URL_TTL=3600


# -----------------------------------------------------------------------------
# [필수] Supabase (서버 전용 — 클라이언트 코드에 절대 노출 금지)
# -----------------------------------------------------------------------------

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 회의 음성 파일이 저장될 Storage 버킷 이름 (기본값: meetings)
SUPABASE_STORAGE_BUCKET=meetings


# -----------------------------------------------------------------------------
# [필수] 보안 — Notion access_token 등 integrations 컬럼 Fernet 암호화
# -----------------------------------------------------------------------------
# 키 생성:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ACTNOTE_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# [필수] Modal 트리거 공유 시크릿 (Inngest 제거 — 완전 서버리스 전환)
# -----------------------------------------------------------------------------
# Next.js /api/trigger-* 가 Modal 웹 엔드포인트를 호출할 때 X-Actnote-Secret 헤더로 보냄.
# 이 값을 Modal Secret "actnote-secrets" 의 MODAL_TRIGGER_SECRET 과 **동일하게** 둔다.
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(32))"
MODAL_TRIGGER_SECRET=
# 배포 후 Modal 이 출력하는 엔드포인트 URL — actnote-web/.env.local 에 설정:
#   MODAL_PIPELINE_TRIGGER_URL, MODAL_PUBLISH_TRIGGER_URL
# 워커는 더 이상 로컬 실행하지 않는다 (modal deploy 로 배포). serve_worker.py 제거됨.


# -----------------------------------------------------------------------------
# [선택] Notion OAuth — 노션 연동·발행 QA 할 때만 채움 (팀 기본 QA 생략 가능)
# -----------------------------------------------------------------------------
# 미설정 시 validate_meeting_for_publication 등에서 Notion 미연동으로 처리됨.

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# INTEG-006-001/002: ACTNOTE 공식 Notion 템플릿 복제 URL.
# - 회의록(INTEG-006-001): 사용자가 복제 후 INTEG-001 (`meeting_db_id`) 로 등록.
# - 액션 트래커(INTEG-006-002): 복제 후 INTEG-002 (`action_db_id`) 로 등록.
# 미설정 시 프론트가 "템플릿 복제" 버튼을 노출하지 않음 (수동 DB 직접 입력만 가능).
NOTION_TEMPLATE_MEETING_URL=
NOTION_TEMPLATE_TICKET_URL=

# notion_sync.py 단독 스모크 테스트용 (운영에선 사용 X)
NOTION_TEST_TOKEN=secret_...
NOTION_TEST_PARENT_PAGE_ID=


# -----------------------------------------------------------------------------
# [선택] 이메일 발송 (NOTI-001, B-3-1)
# -----------------------------------------------------------------------------
# 우선순위 (워커 send_email): SMTP_USER+SMTP_PASSWORD 가 있으면 SMTP → 아니면 RESEND_API_KEY → 없으면 dry-run
#
# --- Gmail SMTP 예시 (Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호 16자) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_FROM=Actnote <you@gmail.com>
#
RESEND_API_KEY=
# Resend: 발신자 문자열은 ASCII만 (표시 이름에 한글·전각 기호 금지). 예: Actnote <noreply@yourdomain.com>
EMAIL_FROM=Actnote <onboarding@resend.dev>
# 메일·초대 링크·OAuth 리다이렉트 베이스 URL — 값에는 URL만 적습니다 (같은 줄에 # 주석을 붙이지 마세요).
NEXT_PUBLIC_APP_URL=https://actnote.xyz


# -----------------------------------------------------------------------------
# [선택] 출력 언어 토글 (임시 한국어 데모용)
# -----------------------------------------------------------------------------
# STT(Whisper) 입력 언어 + LLM 추출 결과 언어를 분기한다. 기본 en(영어).
#   en : 영어 회의록 → 영어 결과 (운영 기본)
#   ko : 한국어 회의록 → 한국어 결과 (요약/결정/액션/섹션 모두 한국어)
# UI 카피·에러/알림 문구는 이 값과 무관(항상 영어). 프론트 변경 없음.
# 운영 반영: Modal Secret "actnote-secrets" 에 동일 값 등록 후 `modal deploy src/modal_app.py`.
# 되돌리기: en 으로 바꾸거나 키 제거 후 재배포. 기존 회의는 재분석해야 언어가 바뀜.
ACTNOTE_OUTPUT_LANG=en


# -----------------------------------------------------------------------------
# [선택] 비용 가드레일
# -----------------------------------------------------------------------------

MAX_COST_PER_MEETING_USD=1.0      # 회의 1건당 예상 비용 초과 시 경고
MAX_TOTAL_COST_USD=10.0           # 누적 비용 초과 시 자동 중단 + 사용자 confirmation
COST_GUARDRAIL_AUTO_APPROVE=false # true 면 confirmation 자동 승인 (CI 전용)


# -----------------------------------------------------------------------------
# [선택] 주기 작업 — 미연결 회의 정리 (`cleanup-orphan-meetings`, Inngest cron 6h)
# -----------------------------------------------------------------------------
# meetings.workspace_id 가 NULL 인 행 + Storage 녹음(best-effort) 삭제.
# 로컬에서 cron 이 돌며 테스트 데이터 지우는 게 싫으면 true 로 끄기.

ACTNOTE_ORPHAN_MEETING_CLEANUP_DISABLED=


# -----------------------------------------------------------------------------
# [선택] 매칭 임계값 튜닝
# -----------------------------------------------------------------------------

# DRAFT-005: assignee 텍스트 → 멤버 임베딩 매칭 컷오프
ACTNOTE_ASSIGNEE_MATCH_THRESHOLD=0.55

# DRAFT-010: 화자(SPEAKER_XX) → 멤버 후보 LLM 추측 컷오프
ACTNOTE_SPEAKER_MATCH_THRESHOLD=0.40
ACTNOTE_SPEAKER_MAX_SAMPLES=10
ACTNOTE_SPEAKER_TOP_K=3


# -----------------------------------------------------------------------------
# [선택] 로컬 스모크 테스트용 UUID (Supabase DB에 실제 존재해야 함)
# -----------------------------------------------------------------------------
# action_resolver / publication / 일부 모듈의 __main__ 실행에 필요.

ACTNOTE_TEST_USER_ID=
ACTNOTE_TEST_WORKSPACE_ID=

# crag.py / policy.py 일부 모듈은 ACTNOTE_ 접두사 없는 변수도 본다 (legacy).
TEST_USER_ID=
TEST_WORKSPACE_ID=
TEST_MEETING_ID=
