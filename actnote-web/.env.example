# -----------------------------------------------------------------------------
# ACTNOTE 웹앱 — 팀 로컬 QA 용 환경변수 (복사해서 .env.local 로 저장하세요.)
# 노션 연동·발행 QA는 포함하지 않습니다. 해당 시 루트 .env 의 NOTION_* 를 서버 라우트에서만 사용.
# -----------------------------------------------------------------------------

# [필수] Supabase — 대시보드 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # anon public (service_role 금지)

# [권장] Storage 버킷명 (워커 SUPABASE_STORAGE_BUCKET 과 동일하게)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=meetings

# [필수] 분석 파이프라인 트리거 — /api/trigger-pipeline 가 Inngest 로 이벤트를 보낼 때 필요
# 로컬: Inngest Dev + 워커 띄운 뒤 임의 값(예: local-dev). 운영: Inngest Cloud Event Key.
INNGEST_EVENT_KEY=

# [로컬 전용] SDK 기본은 Cloud 로 이벤트를 보냄. `npx inngest-cli dev` 를 쓸 때는 반드시 켜서 Dev 서버(8288)로 보내야 Runs에 보임.
# INNGEST_DEV=1
# (포트가 다르면) INNGEST_DEV=http://127.0.0.1:8288

# [권장] 절대 URL (OAuth·이메일 링크·리다이렉트에 쓰일 때). 로컬 QA 예: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [권장] 에러(case 6) 고객센터 안내용 — 기획 확정 주소
NEXT_PUBLIC_SUPPORT_EMAIL=actnote.support@gmail.com

# --- 아래는 노션·메일 QA 시에만 (지금 단계에서는 비워 둬도 됨) ---

# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# RESEND_API_KEY=
# EMAIL_FROM=Actnote <onboarding@resend.dev>
