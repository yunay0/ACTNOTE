# -----------------------------------------------------------------------------
# ACTNOTE 웹앱 — 팀 로컬 QA 용 환경변수 (복사해서 .env.local 로 저장하세요.)
# 노션 연동·발행 QA는 포함하지 않습니다. 해당 시 루트 .env 의 NOTION_* 를 서버 라우트에서만 사용.
# -----------------------------------------------------------------------------

# [필수] Supabase — 대시보드 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # anon public (service_role 금지)
# Google OAuth: Supabase → Authentication → Providers → Google 활성화.
# Redirect URLs 에 앱 `/auth/callback` 추가 (예: http://localhost:3000/auth/callback).

# [선택] Personal 설정의 "Delete My Account" — 서버 Route Handler 전용 (클라이언트에 노출 금지)
# SUPABASE_SERVICE_ROLE_KEY=

# [권장] Storage 버킷명 (워커 SUPABASE_STORAGE_BUCKET 과 동일하게)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=meetings

# [필수] 분석/발행 트리거 — Modal 전환 (Inngest 제거).
# /api/trigger-pipeline · /api/trigger-publish 가 Modal 웹 엔드포인트를 호출한다.
#   1) `modal deploy src/modal_app.py` 후 출력되는 두 엔드포인트 URL 을 아래에 붙여넣기
#   2) MODAL_TRIGGER_SECRET 은 Modal Secret "actnote-secrets" 의 동일 키와 **같은 값**
MODAL_PIPELINE_TRIGGER_URL=
MODAL_PUBLISH_TRIGGER_URL=
MODAL_TRIGGER_SECRET=

# [권장] 절대 URL (OAuth·이메일·초대 링크에 사용). 로컬 QA 예: http://localhost:3000
# 값에는 URL만 두세요 — 같은 줄에 # 로 주석을 붙이면 일부 배포 환경에서 링크가 깨질 수 있습니다.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [권장] 에러(case 6) 고객센터 안내용 — 기획 확정 주소
NEXT_PUBLIC_SUPPORT_EMAIL=ttojo6@gmail.com

# --- 아래는 노션·메일 QA 시에만 (지금 단계에서는 비워 둬도 됨) ---

# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# INTEG-006-001/002: ACTNOTE 공식 Notion 템플릿 복제 URL (프론트 "템플릿 복제" 버튼용)
# NEXT_PUBLIC_NOTION_TEMPLATE_MEETING_URL=
# NEXT_PUBLIC_NOTION_TEMPLATE_TICKET_URL=

# 초대 메일 등 서버 발송: SMTP(Gmail) 또는 Resend 중 하나 (없으면 링크만 반환 — 워커 폴백 제거됨)
#
# Gmail SMTP (앱 비밀번호):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_FROM=Actnote <you@gmail.com>
#
# RESEND_API_KEY=
# EMAIL_FROM=Actnote <onboarding@resend.dev>
